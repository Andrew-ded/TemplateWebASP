{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Database": {
    "Provider": "sqlserver",
    "ConnectionString": "Data Source=localhost;Initial Catalog=TemplateDb;Integrated Security=True;TrustServerCertificate=True;",
